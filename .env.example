# Copy this file to .env and fill in your values
OPENAI_API_KEY=OPENAIAPI-KET

# Database (used when running services outside Docker)
DB_USER=admin
DB_PASS=admin
REDIS_PORT=6379
KAFKA_BROKERS=localhost:9092

# Optional: Real log backends (leave false for demo mode with mock logs)
LOKI_ENABLED=false
LOKI_URL=http://localhost:3100
ES_ENABLED=false
ES_URL=http://localhost:9200
